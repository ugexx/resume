<!-- Mobile menu (hidden by default) -->
<div class="hidden fixed top-[60px] left-0 right-0 bg-bg/95 backdrop-blur-[16px] border-b border-border z-[99] px-5 py-4 flex flex-col gap-3 max-md:flex" id="mobile-menu" style="display:none">
  <a href="/#case-studies" class="text-text-dim hover:text-accent transition-colors text-base py-1">Case Studies</a>
  <a href="/#experience" class="text-text-dim hover:text-accent transition-colors text-base py-1">Experience</a>
