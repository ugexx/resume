---
interface CaseStudy {
  slug: string;
  title: string;
  summary: string;
  metric: string;
  metricLabel: string;
  tags: string[];
}

const studies: CaseStudy[] = [
  {
    slug: "zero-touch",
    title: "Zero-Touch Deployments",
    summary: "Designed a fully automated macOS deployment workflow that eliminated manual imaging and reduced provisioning from hours to under 20 minutes across 2,000+ endpoints.",
    metric: "hours → 20min",
    metricLabel: "Provisioning time reduction",
    tags: ["Jamf Pro", "Apple Business Manager", "macOS", "Bash"],
  },
  {
    slug: "platform-sso",
    title: "Platform SSO & Identity",
    summary: "Implemented macOS Platform SSO with Secure Enclave-backed authentication and Jamf Connect for least-privilege admin access, eliminating legacy password-based auth enterprise-wide.",
    metric: "Passwordless",
    metricLabel: "Authentication model",
    tags: ["Jamf Connect", "Platform SSO", "Entra ID", "Secure Enclave"],
  },
  {
    slug: "live-streaming",
    title: "Live Streaming Infrastructure",
    summary: "Architected broadcast-grade live streaming for company-wide town halls, integrating OBS, ProPresenter, and Microsoft Teams for hybrid events reaching thousands of employees.",
    metric: "Thousands",
    metricLabel: "Employees reached per event",
    tags: ["OBS Studio", "ProPresenter", "Microsoft Teams", "A/V Hardware"],
  },
  {
    slug: "patch-automation",
    title: "Patch Automation",
    summary: "Built macOS and iOS patch management strategy using Jamf Pro, automating compliance reporting and remediation workflows to maintain security posture across the fleet.",
    metric: "Automated",
    metricLabel: "Patch compliance workflow",
    tags: ["Jamf Pro", "macOS", "iOS", "Compliance"],
  },
  {
    slug: "content-caching",
    title: "Content Caching Infrastructure",
    summary: "Deployed Apple Content Caching servers across key network segments, dramatically reducing WAN bandwidth consumption and accelerating software delivery company-wide.",
    metric: "WAN ↓",
    metricLabel: "Bandwidth consumption",
    tags: ["Content Caching", "DNS/DHCP", "Apple", "Networking"],
  },
];
---

<section id="case-studies" class="py-[120px] max-md:py-20">
  <div class="max-w-[1080px] mx-auto px-8 relative z-[1] max-md:px-5">
    <div class="text-[12px] uppercase tracking-[0.2em] text-accent mb-2 anim font-semibold">Case Studies</div>
    <h2 class="text-[clamp(30px,4vw,42px)] font-bold mb-4 leading-[1.15] anim delay-1">Infrastructure at Scale</h2>
    <p class="text-text-dim text-[17px] mb-12 anim delay-2 max-w-[600px]">
      Detailed breakdowns of the problems I've solved, the architecture decisions I've made, and the measurable impact delivered.
    </p>

    <div class="grid grid-cols-[repeat(auto-fill,minmax(320px,1fr))] gap-6">
      {studies.map((study, i) => (
        <a
          href={`/case-studies/${study.slug}`}
          class={`anim group bg-surface border border-border rounded-xl p-7 transition-all duration-300 hover:border-accent hover:-translate-y-1 flex flex-col ${i > 0 ? `delay-${Math.min(i, 4)}` : ""}`}
        >
          <!-- Metric badge -->
          <div class="inline-flex items-center gap-2 self-start mb-4 px-3 py-1.5 bg-accent-dim border border-accent/20 rounded-lg">
            <span class="text-accent text-[20px] font-bold leading-none">{study.metric}</span>
            <span class="text-[11px] text-text-dim uppercase tracking-[0.06em] leading-tight">{study.metricLabel}</span>
          </div>

          <h3 class="text-xl font-bold mb-2.5 leading-[1.3] group-hover:text-accent transition-colors">{study.title}</h3>
          <p class="text-[15px] text-text-dim leading-[1.65] mb-4 flex-1">{study.summary}</p>

          <div class="flex flex-wrap gap-1.5 mt-auto">
            {study.tags.map((tag) => (
              <span class="font-mono text-[10px] tracking-[0.06em] px-2.5 py-1 border border-border rounded text-text-dim uppercase group-hover:border-accent/30 transition-colors">
                {tag}
              </span>
            ))}
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
