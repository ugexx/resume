---
import Base from "./Base.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";

export interface Props {
  title: string;
  description: string;
  metric: string;
  metricLabel: string;
}

const { title, description, metric, metricLabel } = Astro.props;
---

<Base title={`${title} — Colton Fouch`} description={description}>
  <Nav />
  <article class="max-w-[780px] mx-auto px-8 pt-32 pb-24 max-md:px-5">
    <a href="/#case-studies" class="inline-flex items-center text-[14px] text-text-dim hover:text-accent transition-colors mb-8">
      <span class="mr-1">←</span> Back to Case Studies
    </a>

    <!-- Metric badge -->
    <div class="inline-flex items-center gap-2 mb-6 px-4 py-2 bg-accent-dim border border-accent/20 rounded-lg">
      <span class="text-accent text-[24px] font-bold leading-none">{metric}</span>
      <span class="text-[13px] text-text-dim uppercase tracking-[0.06em] leading-tight">{metricLabel}</span>
    </div>

    <h1 class="text-[clamp(32px,5vw,48px)] font-bold mb-4 leading-[1.1] tracking-[-0.025em]">{title}</h1>
    <p class="text-[18px] text-text-dim leading-[1.7] mb-12">{description}</p>

    <slot />

    <footer class="mt-16 pt-8 border-t border-border">
      <a href="/#case-studies" class="inline-flex items-center text-[14px] text-text-dim hover:text-accent transition-colors">
        <span class="mr-1">←</span> Back to Case Studies
      </a>
    </footer>
  </article>
  <Footer />
</Base>
