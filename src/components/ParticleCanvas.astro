<section class="relative min-h-screen flex items-center justify-center overflow-hidden" id="dot-matrix">
  <canvas id="dot-canvas" class="absolute inset-0 z-0"></canvas>
  <div class="scanline-overlay"></div>
  <div class="relative z-[1] text-center px-8">
    <div class="font-mono text-[clamp(48px,8vw,80px)] font-bold text-text leading-none mb-4 tracking-[-0.03em]">
      colton<span class="text-accent">.</span>fouch
    </div>
    <div class="font-mono text-[clamp(14px,2vw,18px)] text-text-dim tracking-[0.15em] uppercase">
      Platform &middot; Infrastructure &middot; Production
    </div>
  </div>
</section>

<script>
  class DotMatrix {
    canvas: HTMLCanvasElement;
    ctx: CanvasRenderingContext2D;
    dots: Array<{
      baseX: number;
      baseY: number;
      size: number;
      phase: number;
    }>;
    mouse: { x: number; y: number };
    time: number;

    constructor(canvas: HTMLCanvasElement) {
      this.canvas = canvas;
      this.ctx = canvas.getContext("2d")!;
      this.dots = [];
      this.mouse = { x: -1000, y: -1000 };
      this.time = 0;
      this.resize();
      window.addEventListener("resize", () => this.resize());
      window.addEventListener("mousemove", (e) => {
        this.mouse.x = e.clientX;
        this.mouse.y = e.clientY;
      });
      this.init();
      this.animate();
    }

    resize() {
      this.canvas.width = window.innerWidth;
      this.canvas.height = window.innerHeight;
      this.init();
    }

    init() {
      this.dots = [];
      const spacing = 36;
      const cols = Math.ceil(window.innerWidth / spacing) + 2;
      const rows = Math.ceil(window.innerHeight / spacing) + 2;
      for (let i = 0; i < cols; i++) {
        for (let j = 0; j < rows; j++) {
          this.dots.push({
            baseX: i * spacing,
            baseY: j * spacing,
            size: 1.5 + Math.random() * 0.5,
            phase: Math.random() * Math.PI * 2,
          });
        }
      }
    }

    animate() {
      this.time += 0.016;
      this.ctx.clearRect(0, 0, this.canvas.width, this.canvas.height);
      const scrollY = window.scrollY;
      const section = this.canvas.parentElement!;
      const sectionTop = section.offsetTop;
      const sectionHeight = section.offsetHeight;

      for (const dot of this.dots) {
        const screenY = dot.baseY - scrollY * 0.03;
        const dx = this.mouse.x - dot.baseX;
        const dy = this.mouse.y - screenY;
        const dist = Math.sqrt(dx * dx + dy * dy);
        const maxDist = 200;

        let size: number;
        let alpha: number;

        if (dist < maxDist) {
          const force = 1 - dist / maxDist;
          size = dot.size + force * 4;
          alpha = 0.35 + force * 1.2;
        } else {
          size = dot.size;
          alpha = 0.35;
        }

        // Subtle pulse
        const pulse = 1 + Math.sin(this.time * 2 + dot.phase) * 0.12;
        alpha *= pulse;

        // Sage green (#4A7C59) in rgb: 74, 124, 89
        this.ctx.beginPath();
        this.ctx.arc(dot.baseX, screenY, size, 0, Math.PI * 2);
        this.ctx.fillStyle = `rgba(74,124,89,${Math.min(alpha, 0.85)})`;
        this.ctx.fill();
      }

      requestAnimationFrame(() => this.animate());
    }
  }

  const c = document.getElementById("dot-canvas") as HTMLCanvasElement;
  if (c) {
    new DotMatrix(c);
  }
</script>
