<canvas id="dot-canvas" class="fixed inset-0 z-0 pointer-events-none" style="opacity:0.06"></canvas>

<script>
  class DotMatrix {
    canvas: HTMLCanvasElement;
    ctx: CanvasRenderingContext2D;
    dots: Array<{
      baseX: number;
      baseY: number;
      size: number;
      opacity: number;
    }>;
    mouse: { x: number; y: number };

    constructor(canvas: HTMLCanvasElement) {
      this.canvas = canvas;
      this.ctx = canvas.getContext("2d")!;
      this.dots = [];
      this.mouse = { x: -1000, y: -1000 };
      this.resize();
      window.addEventListener("resize", () => this.resize());
      window.addEventListener("mousemove", (e) => {
        this.mouse.x = e.clientX;
        this.mouse.y = e.clientY;
      });
      this.init();
      this.animate();
    }

    resize() {
      this.canvas.width = window.innerWidth;
      this.canvas.height = window.innerHeight;
      this.init();
    }

    init() {
      this.dots = [];
      const spacing = 48;
      const cols = Math.ceil(window.innerWidth / spacing) + 1;
      const rows = Math.ceil(window.innerHeight / spacing) + 1;
      for (let i = 0; i < cols; i++) {
        for (let j = 0; j < rows; j++) {
          this.dots.push({
            baseX: i * spacing,
            baseY: j * spacing,
            size: 1,
            opacity: 1.0,
          });
        }
      }
    }

    animate() {
      this.ctx.clearRect(0, 0, this.canvas.width, this.canvas.height);
      const scrollY = window.scrollY;

      for (const dot of this.dots) {
        const screenY = dot.baseY - scrollY * 0.05;
        const dx = this.mouse.x - dot.baseX;
        const dy = this.mouse.y - screenY;
        const dist = Math.sqrt(dx * dx + dy * dy);
        const maxDist = 180;

        let size: number;
        let opacity: number;

        if (dist < maxDist) {
          const force = 1 - dist / maxDist;
          size = dot.size + force * 3;
          opacity = 1.0 + force * 1.5;
        } else {
          size = dot.size;
          opacity = 1.0;
        }

        // Muted gold (#BFA181) in rgb: 191, 161, 129
        this.ctx.beginPath();
        this.ctx.arc(dot.baseX, screenY, size, 0, Math.PI * 2);
        this.ctx.fillStyle = `rgba(191,161,129,${Math.min(opacity * 0.12, 0.5)})`;
        this.ctx.fill();
      }

      requestAnimationFrame(() => this.animate());
    }
  }

  const c = document.getElementById("dot-canvas") as HTMLCanvasElement;
  if (c) {
    new DotMatrix(c);
  }
</script>
